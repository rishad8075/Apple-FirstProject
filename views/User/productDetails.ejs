<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.productName %> | Premium Store</title>
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --primary: #000000;
      --accent: #0071e3;
      --surface: #f5f5f7;
      --text-muted: #6e6e73;
      --success: #28a745;
      --danger: #dc3545;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: #ffffff;
      color: #1d1d1f;
      overflow-x: hidden;
    }

    .product-main-container { padding-top: 40px; }
    .gallery-column { position: sticky; top: 100px; height: fit-content; }
    
    .hero-stage {
      background: var(--surface);
      border-radius: 32px;
      padding: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .main-img-display {
      max-width: 100%;
      max-height: 480px;
      object-fit: contain;
      mix-blend-mode: multiply;
      filter: drop-shadow(0 20px 30px rgba(0,0,0,0.05));
    }

    .thumb-nav { display: flex; gap: 15px; margin-top: 25px; justify-content: center; }
    .thumb-cube {
      width: 80px; height: 80px; border-radius: 16px; background: var(--surface);
      padding: 10px; cursor: pointer; border: 2px solid transparent; transition: all 0.3s;
    }
    .thumb-cube.active { border-color: var(--primary); background: #fff; transform: translateY(-5px); }
    .thumb-cube img { width: 100%; height: 100%; object-fit: contain; mix-blend-mode: multiply; }

    .product-label { font-size: 11px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 12px; }
    .product-h1 { font-size: 3rem; font-weight: 800; line-height: 1.1; letter-spacing: -1.5px; margin-bottom: 20px; }

    .price-tag-large { font-size: 2.8rem; font-weight: 700; letter-spacing: -1px; }
    .strike-price { color: var(--text-muted); text-decoration: line-through; font-size: 1.4rem; margin-left: 15px; font-weight: 400; }
    
    .offer-box {
      display: inline-flex; align-items: center; background: #eef7ff; color: var(--accent);
      padding: 6px 14px; border-radius: 100px; font-size: 13px; font-weight: 700; margin-left: 15px;
    }

    /* --- Stock & Quantity UI --- */
    .stock-badge {
        font-size: 13px; font-weight: 700; padding: 6px 16px; border-radius: 50px; display: inline-block; margin-bottom: 20px;
    }
    .stock-in { background: #e8f5e9; color: var(--success); }
    .stock-low { background: #fff3e0; color: #ef6c00; }
    .stock-out { background: #ffebee; color: var(--danger); }

    .qty-selector {
        display: flex; align-items: center; background: var(--surface);
        border-radius: 100px; width: fit-content; padding: 4px; margin-bottom: 25px;
    }
    .qty-btn {
        width: 40px; height: 40px; border-radius: 50%; border: none; background: #fff;
        display: flex; align-items: center; justify-content: center; transition: 0.2s;
    }
    .qty-btn:hover { background: var(--primary); color: #fff; }
    .qty-input {
        width: 50px; border: none; background: transparent; text-align: center; font-weight: 700;
    }

    .btn-buy-now {
      background: var(--primary); color: #fff; border-radius: 100px; padding: 20px 40px;
      font-weight: 700; font-size: 18px; border: none; width: 100%; transition: 0.3s;
    }
    .btn-buy-now:hover { background: #333; transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.15); }
  /* --- Redesigned Related Products --- */

    .related-section { background-color: var(--surface); border-radius: 50px; padding: 80px 0; margin-top: 100px; }

    .related-title { font-size: 2.2rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 40px; text-align: center; }



    .collection-card {

      background: #fff;

      border-radius: 24px;

      padding: 25px;

      height: 100%;

      transition: all 0.4s;

      border: 1px solid transparent;

      text-decoration: none;

      display: block;

      color: inherit;

    }



    .collection-card:hover {

      transform: translateY(-10px);

      box-shadow: 0 30px 60px rgba(0,0,0,0.08);

      border-color: #eee;

    }



    .collection-img-wrapper {

      background: var(--surface);

      border-radius: 18px;

      padding: 30px;

      margin-bottom: 20px;

      height: 220px;

      display: flex;

      align-items: center;

      justify-content: center;

      overflow: hidden;

    }



    .collection-img-wrapper img { max-width: 100%; max-height: 100%; object-fit: contain; mix-blend-mode: multiply; transition: transform 0.5s; }

    .collection-card:hover img { transform: scale(1.1); }



    .collection-card h6 { font-weight: 700; font-size: 16px; margin-bottom: 5px; }

    .collection-card p { color: var(--text-muted); font-size: 13px; margin-bottom: 15px; }



    .btn-circle-view {

      width: 40px;

      height: 40px;

      border-radius: 50%;

      background: var(--primary);

      color: #fff;

      display: flex;

      align-items: center;

      justify-content: center;

      transition: 0.3s;

      margin-top: auto;

    }



    .img-zoom-result {

      width: 500px;

      height: 500px;

      position: absolute;

      left: 105%;

      top: 0;

      z-index: 100;

      border-radius: 30px;

      box-shadow: 0 30px 70px rgba(0,0,0,0.2);

      display: none;

      background-repeat: no-repeat;

      background-color: #fff;

    }



    @media (max-width: 991px) {

      .product-h1 { font-size: 2rem; }

      .price-tag-large { font-size: 2rem; }

      .hero-stage { padding: 30px; min-height: 300px; }

      .img-zoom-result { display: none !important; }

    }
  </style>
</head>
<body>

<%- include("../partials/header.ejs") %>

<div class="container product-main-container">
  <div class="row g-5">
    
    <div class="col-lg-7 gallery-column">
      <div class="hero-stage shadow-sm">
        <button class="wishlist-btn-action position-absolute top-0 end-0 m-4 btn bg-white rounded-circle shadow-sm p-3" data-id="<%= product._id %>" style="z-index: 10;">
          <i class="<%= (product.isWishlisted) ? 'fa-solid' : 'fa-regular' %> fa-heart" id="wishlistIcon" style="color: #ff3b30; font-size: 22px;"></i>
        </button>
        
        <% let mainImage = (product.variants[0] && product.variants[0].images[0]) || '/uploads/product-images/default.png'; %>
        <img id="mainImage" src="<%= mainImage %>" class="main-img-display" alt="<%= product.productName %>">
        <div id="zoomResult" class="img-zoom-result"></div>
      </div>

      <div class="thumb-nav">
        <% if (product.variants[0] && product.variants[0].images.length > 0) { %>
          <% product.variants[0].images.forEach((img, idx) => { %>
            <div class="thumb-cube <%= idx === 0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                <img src="<%= img %>" alt="thumbnail">
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="product-details-wrap py-2">
        <span class="product-label"><%= product.brand %> &bull; <%= product.category.name %></span>
        <h1 class="product-h1"><%= product.productName %></h1>
        
        <% const variant = product.variants[0] || {}; %>
        
        <div class="stock-status">
            <% if (variant.stock <= 0) { %>
                <span class="stock-badge stock-out"><i class="bi bi-x-circle me-2"></i>Currently Out of Stock</span>
            <% } else if (variant.stock < 10) { %>
                <span class="stock-badge stock-low"><i class="bi bi-exclamation-triangle me-2"></i>Only <%= variant.stock %> items left!</span>
            <% } else { %>
                <span class="stock-badge stock-in"><i class="bi bi-check-circle me-2"></i>In Stock & Ready to Ship</span>
            <% } %>
        </div>

        <div class="d-flex align-items-center mb-4">
          <div class="bg-dark text-white px-3 py-1 rounded-pill fw-bold me-3" style="font-size: 13px;">
            <i class="bi bi-star-fill text-warning me-1"></i> <%= product.rating || '4.8' %>
          </div>
          <span class="text-muted fw-medium" style="font-size: 14px;"><%= (product.reviews || []).length %> Verified Reviews</span>
        </div>

        <div class="price-section mb-4">
          <div class="d-flex align-items-center">
            <span class="price-tag-large">₹<%= priceData.finalPrice.toLocaleString() %></span>
            <% if(priceData.appliedOffer > 0) { %>
              <span class="strike-price">₹<%= variant.regularPrice.toLocaleString() %></span>
              <span class="offer-box"><%= priceData.appliedOffer %>% OFF</span>
            <% } %>
          </div>
        </div>

        <% if(variant.stock > 0) { %>
        <label class="fw-bold mb-2 d-block" style="font-size: 14px;">Select Quantity</label>
        <div class="qty-selector">
            <button class="qty-btn" onclick="updateQty(-1)"><i class="bi bi-dash"></i></button>
            <input type="number" id="qtyInput" class="qty-input" value="1" min="1" max="<%= variant.stock %>" readonly>
            <button class="qty-btn" onclick="updateQty(1)"><i class="bi bi-plus"></i></button>
        </div>
        <% } %>

        <div class="purchase-area">
          <button id="addToCartBtn" 
                  class="btn-buy-now shadow-lg" 
                  data-product-id="<%= product._id %>" 
                  data-variant-id="<%= variant._id %>" 
                  <%= variant.stock <= 0 ? 'disabled' : '' %>>
            <i class="bi bi-bag-plus me-2"></i>
            <%= variant.stock <= 0 ? 'Notify Me When Available' : 'Add to Shopping Bag' %>
          </button>
        </div>

        <div class="row g-2 mt-4">
            <div class="col-4 text-center">
                <i class="bi bi-truck text-muted" style="font-size: 20px;"></i>
                <p style="font-size: 10px;" class="fw-bold mt-1">FREE SHIPPING</p>
            </div>
            <div class="col-4 text-center border-start border-end">
                <i class="bi bi-shield-lock text-muted" style="font-size: 20px;"></i>
                <p style="font-size: 10px;" class="fw-bold mt-1">SECURE PAY</p>
            </div>
            <div class="col-4 text-center">
                <i class="bi bi-arrow-repeat text-muted" style="font-size: 20px;"></i>
                <p style="font-size: 10px;" class="fw-bold mt-1">7 DAYS RETURN</p>
            </div>
        </div>

        <div class="mt-5 pt-4 border-top">
            <h5 class="fw-800 mb-3">Description</h5>
            <p class="text-muted" style="line-height: 1.8; font-size: 15px;">
                <%= product.description %>
            </p>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="related-section">
    <div class="container">
        <h2 class="text-center fw-800 mb-5">You May Also Like</h2>
        <div class="row g-4">
            <% relatedProducts.forEach(p => { %>
                <div class="col-6 col-md-3">
                    <a href="/productDetails/<%= p._id %>" class="collection-card shadow-sm">
                        <div class="collection-img-wrapper">
                            <img src="<%= p.variants[0].images[0] %>" alt="<%= p.productName %>">
                        </div>
                        <h6 class="text-truncate"><%= p.productName %></h6>
                        <p class="small"><%= p.brand %></p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">₹<%= p.variants[0].regularPrice.toLocaleString() %></span>
                            <div class="btn-circle-view"><i class="bi bi-arrow-right"></i></div>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<%- include('../partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
// Quantity Logic
function updateQty(change) {
    const input = document.getElementById('qtyInput');
    let val = parseInt(input.value) + change;
    if(val >= 1 && val <= parseInt(input.max)) input.value = val;
}

// Add to Cart Logic
document.getElementById('addToCartBtn')?.addEventListener('click', async function() {
  const btn = this;
  const quantity = document.getElementById('qtyInput')?.value || 1;
  btn.disabled = true;

  try {
    const res = await fetch('/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ 
          productId: btn.dataset.productId, 
          variantId: btn.dataset.variantId, 
          quantity: parseInt(quantity) 
      })
    });
    const data = await res.json();
    if (data.success) {
      Swal.fire({
        icon: 'success', title: 'Added to Bag',
        showCancelButton: true, confirmButtonText: 'Checkout', confirmButtonColor: '#000'
      }).then(r => { if (r.isConfirmed) window.location.href = '/cart'; });
    } else {
      Swal.fire({ icon: 'error', title: 'Error', text: data.message });
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong.' });
  } finally { btn.disabled = false; }
});

// Gallery & Zoom (Same as your preferred logic)
function enableZoom(imgID, resultID) {
  const img = document.getElementById(imgID);
  const result = document.getElementById(resultID);
  const scale = 2.5;
  img.addEventListener("mouseenter", () => { if(window.innerWidth > 991) result.style.display = "block"; });
  img.addEventListener("mouseleave", () => { result.style.display = "none"; });
  img.addEventListener("mousemove", (e) => {
    const rect = img.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    result.style.backgroundImage = `url(${img.src})`;
    result.style.backgroundSize = img.width * scale + "px " + img.height * scale + "px";
    result.style.backgroundPosition = `${-(x * scale - result.offsetWidth/2)}px ${-(y * scale - result.offsetHeight/2)}px`;
  });
}
enableZoom("mainImage", "zoomResult");

function changeImage(src, thumb) {
  const main = document.getElementById("mainImage");
  main.style.opacity = '0';
  setTimeout(() => {
    main.src = src;
    main.style.opacity = '1';
  }, 200);
  document.querySelectorAll(".thumb-cube").forEach(t => t.classList.remove("active"));
  thumb.classList.add("active");
}
</script>
</body>
</html>